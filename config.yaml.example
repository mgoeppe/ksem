# Kostal KSEM Scraper Configuration
# Copy this to config.yaml and set your values

meter:
  # Hostname or IP address of your KSEM meter
  host: ksem.fritz.box

  # KSEM password (username is always "admin")
  password: "your-password-here"

output:
  # Output format: "tui" (terminal UI), "json", or "sqlite"
  format: tui

  # For JSON output: optional file path (leave empty for stdout)
  # For SQLite output: required database file path (e.g., "ksem.db")
  file_path: ""

  # Output interval as Go duration (for JSON and SQLite formats)
  # Examples: 1s (1 second), 5s, 30s, 1m (1 minute), 5m, 1h (1 hour)
  # Controls how often data is written
  interval: "1s"

# Enable debug logging (shows protobuf messages, auth details, etc.)
debug: false
